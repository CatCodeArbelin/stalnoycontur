APP_NAME="Stalnoy Contur API"
DATABASE_URL="sqlite:///./stalnoycontur.db"
CORS_ORIGINS="http://localhost:3000"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_MAX_SIZE_BYTES=10485760

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Optional permanent bearer token. If omitted, /admin/auth/login returns a signed token.
ADMIN_TOKEN=
ADMIN_JWT_SECRET=
ADMIN_TOKEN_TTL_SECONDS=43200
UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
